# ========================
# Application
# ========================
APP_NAME="Sign Language"
VERSION="0.1.0"
STATUS="DEVELOPMENT"  # DEVELOPMENT | PRODUCTION
DEBUG=true  # Omit or set to false in PRODUCTION

# ========================
# Logging
# ========================
LOG_LEVEL="DEBUG"  # CRITICAL | ERROR | WARNING | INFO | DEBUG | NOTSET
LOG_PATH="logs/app.log"

# ========================
# CORS
# ========================
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ========================
# Server
# ========================
SERVER_HOST="0.0.0.0"
SERVER_PORT=8000

# ========================
# Inference thresholds
# ========================
# EfficientNet confidence below which the landmark MLP fallback is tried
EFFICIENTNET_CONFIDENCE_THRESHOLD=0.70
# Landmark MLP confidence required to override an uncertain EfficientNet prediction
LANDMARK_OVERRIDE_THRESHOLD=0.90

# ========================
# Sequence builder (seconds)
# ========================
# How long a stable prediction must be held before it is committed as a letter
SEQUENCE_LETTER_HOLD_SEC=1.0
# Minimum gap required between two consecutive committed letters
SEQUENCE_COOLDOWN_SEC=1.0
# Duration of hand-absent silence that triggers an automatic space insertion
SEQUENCE_SPACE_PAUSE_SEC=1.5
# Brief gap during which a missing stable letter is treated as a noisy frame
SEQUENCE_STABLE_GRACE_SEC=0.4

# ========================
# Prediction smoother
# ========================
# Number of recent frames kept in the majority-vote window
SMOOTHER_WINDOW_SIZE=15
# Votes needed to acquire stability  (10/15 ≈ 66 % with defaults)
SMOOTHER_ACQUIRE_THRESHOLD=10
# Votes needed to keep an already-stable letter  (7/15 ≈ 46 % with defaults)
SMOOTHER_STICKY_THRESHOLD=7
# Per-frame confidence floor; frames below this are excluded from smoothing
SMOOTHER_MIN_CONFIDENCE=0.55

# ========================
# MLflow
# ========================
MLFLOW_ENABLED=false

# MLflow tracking target.
#
# Local options:
# - File tracking, no server:
#   MLFLOW_TRACKING_URI="file:./logs/mlflow"
#
# - Local MLflow server:
#   MLFLOW_TRACKING_URI="http://localhost:5000"
#
# Docker/on-prem option:
# - From host machine:
#   MLFLOW_TRACKING_URI="http://localhost:5000"
# - From another container in the same compose network:
#   MLFLOW_TRACKING_URI="http://mlflow:5000"
#
# Azure option:
# - Leave empty and let Azure ML configure/resolve tracking,
#   or set the Azure ML workspace tracking URI explicitly.
MLFLOW_TRACKING_URI=""

MLFLOW_EXPERIMENT_NAME="sign-language-training"
MLFLOW_RUN_NAME=""
MLFLOW_AUTOLOG=true
MLFLOW_LOG_ARTIFACTS=true

# ========================
# Azure ML SDK v2
# ========================
AZURE_SUBSCRIPTION_ID=""
AZURE_RESOURCE_GROUP=""
AZURE_WORKSPACE=""

# Azure authentication mode:
# interactive -> opens browser login window, best for local development
# default     -> uses Azure CLI login, best after running `az login`
# managed_identity -> uses Azure managed identity inside Azure ML jobs
AZURE_AUTH_MODE="interactive"

# Attached Kubernetes compute target used by Azure ML jobs and online endpoints,
# for example lambda-0. Required when deploying a Kubernetes online endpoint.
AZURE_COMPUTE_TARGET=""

# Optional. Leave empty to select the first workspace environment returned by Azure.
# Leave version empty to use the latest registered version for the selected name.
AZURE_ENVIRONMENT_NAME=""
AZURE_ENVIRONMENT_VERSION=""

# Optional. Endpoint deployment environment. If empty, endpoint scripts fall back
# to AZURE_ENVIRONMENT_NAME / AZURE_ENVIRONMENT_VERSION.
AZURE_INFERENCE_ENVIRONMENT_NAME=""
AZURE_INFERENCE_ENVIRONMENT_VERSION=""

# Raw ImageFolder data asset registered in Azure ML.
# Expected structure:
# data/raw/A/*.png
# data/raw/B/*.png
# ...
AZURE_RAW_DATA_ASSET_NAME="ngt-raw"
AZURE_RAW_DATA_ASSET_VERSION="1"

# Optional. Use this if the pretrained checkpoint is registered as an Azure ML asset.
# Leave empty if the checkpoint is included locally in the submitted job context.
AZURE_PRETRAINED_CHECKPOINT_ASSET_NAME=""
AZURE_PRETRAINED_CHECKPOINT_ASSET_VERSION=""

# Azure ML Kubernetes instance type.
# Options visible in your workspace:
# gpu, cpu-xl, cpu-large, cpu-med, cpu-small, defaultinstancetype
# Leave empty to let code choose based on AZURE_PREFER_GPU.
AZURE_INSTANCE_TYPE=""

# Used only when AZURE_INSTANCE_TYPE is empty.
# true  -> use gpu
# false -> use strongest CPU, currently cpu-xl
AZURE_PREFER_GPU=false

# ========================
# Standalone Azure ML endpoint API
# ========================
# Separate from the main frontend/backend API. Run with:
# poetry run sign-language-azure-api --reload
AZURE_API_APP_NAME="Sign Language Azure API"
AZURE_API_HOST="0.0.0.0"
AZURE_API_PORT=8010
# Secret/local only. Copy from Azure ML Studio -> endpoint -> Consume.
AZURE_API_ONLINE_ENDPOINT_URL=""
AZURE_API_ONLINE_ENDPOINT_KEY=""
AZURE_API_ONLINE_TIMEOUT_SECONDS=10
AZURE_API_ONLINE_MODEL_VERSION=""
AZURE_API_DEFAULT_DEPLOYMENT=""
AZURE_API_COLLECT_STORAGE_ACCOUNT=""
AZURE_API_COLLECT_CONTAINER="signlang-r2-collected"
# Secret. Container-scoped SAS without a leading "?".
AZURE_API_COLLECT_SAS_TOKEN=""
AZURE_API_COLLECT_PREFIX="pending"
AZURE_API_COLLECT_MAX_BYTES=5000000

# ========================
# Training
# ========================
TRAINING_BEST_CHECKPOINT_NAME="best_ngt_model_v2.pth"
TRAINING_HISTORY_FILENAME="ngt_training_history.json"
TRAINING_METRICS_FILENAME="ngt_metrics.json"
TRAINING_REPORT_FILENAME="ngt_classification_report.txt"

TRAINING_IMG_SIZE=224
TRAINING_BATCH_SIZE=16
TRAINING_LEARNING_RATE=0.0001
TRAINING_EPOCHS=30
TRAINING_PATIENCE=7
TRAINING_VAL_SPLIT=0.2
TRAINING_TARGET_ACCURACY=0.85
TRAINING_SEED=42
TRAINING_N_SPLITS=1
TRAINING_NUM_WORKERS=4
TRAINING_PIN_MEMORY=true
TRAINING_ETA_MIN=0.000001
TRAINING_EXPECTED_NUM_CLASSES=22

# local | azure
TRAINING_DATA_SOURCE="local"
TRAINING_LOCAL_DATA_DIR="data/raw"
TRAINING_AZURE_DATA_DIR="../data/sign_image"

# ========================
# Model paths
# ========================
IMG_SIZE=224
MODEL_PATH="models/best_ngt_model_v2.pth"
LM_MODEL_PATH="models/best_landmark_mlp.pth"
HAND_LANDMARKER_PATH="models/hand_landmarker.task"

# Built frontend output directory.
# Created after running the frontend build command.
FRONTEND_BUILD_DIR="src/frontend/dist"

# ========================
# Training trigger API
# ========================
TRAINING_TRIGGER_API_KEY=""
TRAINING_TRIGGER_DATA_DIR="data/raw"
TRAINING_TRIGGER_STATE_PATH="state/training_trigger_state.json"
TRAINING_TRIGGER_MIN_NEW_IMAGES=10
TRAINING_TRIGGER_INTERVAL_DAYS=7
TRAINING_TRIGGER_EXPERIMENT_NAME="sign-language-training"
